PAGESPEED_API_KEY=your_pagespeed_api_key_here
GOOGLE_CLIENT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"
GSC_SITE_URL=https://nouncompass.me/
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=replace_with_brevo_smtp_login
BREVO_SMTP_PASSWORD=replace_with_brevo_smtp_key
CONTACT_FORM_FROM="NounCompass Support <support@nouncompass.me>"
CONTACT_FORM_AUTOREPLY_FROM="NounCompass Support <support@nouncompass.me>"
CONTACT_FORM_TO=support@nouncompass.me
CONTACT_FORM_RATE_LIMIT_WINDOW_MINUTES=15
CONTACT_FORM_RATE_LIMIT_MAX=3
CONTACT_FORM_DUPLICATE_WINDOW_MINUTES=10

# NounCompass platform (Supabase)
NEXT_PUBLIC_SITE_URL=https://nouncompass.me
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
INITIAL_SUPER_ADMIN_EMAIL=owner@example.com

# Platform feature flags. Public exam-prep landing pages default on; protected
# features require their service credentials even when a flag is enabled.
FEATURE_ACCOUNTS=true
FEATURE_DASHBOARD=true
FEATURE_EXAM_PREP=true
FEATURE_CHECKOUT=false
FEATURE_ADMIN=true

# Flutterwave Standard. Keep both secrets server-side. Test mode is the safe
# default; do not set live mode until the payment and legal launch gates pass.
FLUTTERWAVE_ENVIRONMENT=test
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_replace_me
FLUTTERWAVE_WEBHOOK_SECRET=replace_with_a_random_secret_hash
SEMESTER_PASS_AMOUNT_KOBO=250000
SEMESTER_PASS_DURATION_DAYS=180

# Daily Vercel operations job
CRON_SECRET=replace_with_at_least_16_random_characters
